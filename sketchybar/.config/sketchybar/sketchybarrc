#!/usr/bin/env bash
CONFIG_DIR="$HOME/.config/sketchybar"
PLUGIN_DIR="$CONFIG_DIR/plugins"
source "$CONFIG_DIR/colors.sh"

FONT="Liga SFMono Nerd Font"
HEIGHT=32

# bar -->
bar=(
height=$HEIGHT
position=top
color=0x00000000
padding_left=0
padding_right=0
corner_radius=0
border_width=0
y_offset=6
margin=6
sticky=on
)
sketchybar --bar "${bar[@]}"
# <--

# defaults -->
default=(
icon.font="$FONT:Regular:14.0"
icon.color=$FG
label.font="$FONT:Regular:13.0"
label.color=$FG
padding_left=4
padding_right=4
icon.padding_left=4
icon.padding_right=2
label.padding_left=4
label.padding_right=4
background.corner_radius=16
background.height=24
background.drawing=off
)
sketchybar --default "${default[@]}"
# <--

# spaces (driven by yabai signal space_focus) -->
sketchybar --add event yabai_spaces_change
sketchybar --add event yabai_windows_change

# hidden driver: reconciles space items from yabai on every relevant change
sketchybar --add item spaces_driver left \
--set spaces_driver drawing=off updates=on script="$PLUGIN_DIR/spaces.sh" \
--subscribe spaces_driver yabai_spaces_change yabai_windows_change
# -- <--

# spaces bracket: rounded block hugging the left -->
# the spaces bracket is built dynamically in plugins/spaces.sh
# -- <--

# right cluster: data block, mirrors the spaces bracket -->
clock=(
icon.drawing=off
update_freq=10
script="$PLUGIN_DIR/clock.sh"
)
sketchybar --add item clock right \
--set clock "${clock[@]}"

date=(
icon.drawing=off
update_freq=30
script="$PLUGIN_DIR/date.sh"
)
sketchybar --add item date right \
--set date "${date[@]}"

battery=(
update_freq=120
script="$PLUGIN_DIR/battery.sh"
)
sketchybar --add item battery right \
--set battery "${battery[@]}" \
--subscribe battery power_source_change

wifi=(
update_freq=10
script="$PLUGIN_DIR/wifi.sh"
)
sketchybar --add item wifi right \
--set wifi "${wifi[@]}"

data=(
background.color=$BASE
background.corner_radius=20
background.height=$HEIGHT
background.border_color=$BG
background.border_width=2
background.padding_left=8
background.padding_right=8
)
sketchybar --add bracket data clock date battery wifi \
--set data "${data[@]}"
# -- <--

# initial render
"$PLUGIN_DIR/spaces.sh"

sketchybar --update
