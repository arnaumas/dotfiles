#!/usr/bin/env bash
CONFIG_DIR="$HOME/.config/sketchybar"
PLUGIN_DIR="$CONFIG_DIR/plugins"
source "$CONFIG_DIR/colors.sh"

FONT="Liga SFMono Nerd Font"
HEIGHT=32

# bar -->
bar=(
height=$HEIGHT
position=top
color=0x00000000
padding_left=0
padding_right=0
corner_radius=0
border_width=0
y_offset=6
margin=6
sticky=on
)
sketchybar --bar "${bar[@]}"
# <--

# defaults -->
default=(
icon.font="$FONT:Regular:14.0"
icon.color=$FG
label.font="$FONT:Regular:13.0"
label.color=$FG
padding_left=4
padding_right=4
icon.padding_left=4
icon.padding_right=2
label.padding_left=2
label.padding_right=4
background.corner_radius=16
background.height=24
background.drawing=off
)
sketchybar --default "${default[@]}"
# <--

# spaces (driven by yabai signal space_focus) -->
sketchybar --add event space_focus

add_space () { # $1=label
space=(
label="$1"
click_script="yabai -m space --focus $1"
script="$PLUGIN_DIR/space.sh"
)
sketchybar --add item space."$1" left \
--set space."$1" "${space[@]}" \
--subscribe space."$1" space_focus
}

for sp in mail web chat misc term latex read; do add_space "$sp"; done
# -- <--

# spaces bracket: rounded block hugging the left -->
spaces=(
background.color=$BG
background.corner_radius=20
background.height=$HEIGHT
background.border_color=$DIM
background.border_width=2
)
sketchybar --add bracket spaces '/space\..*/' \
--set spaces "${spaces[@]}"
