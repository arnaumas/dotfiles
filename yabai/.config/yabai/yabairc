# set ft=sh

yabai -m signal --add event=dock_did_restart action="sudo yabai --load-sa"
sudo yabai --load-sa

yabai -m config layout bsp
yabai -m config window_placement second_child
yabai -m config split_ratio 0.5
yabai -m config auto_balance off

yabai -m config top_padding    0
yabai -m config bottom_padding 2
yabai -m config left_padding   2
yabai -m config right_padding  2
yabai -m config window_gap     2

# yabai -m config mouse_follows_focus on
yabai -m config mouse_modifier       fn
yabai -m config mouse_action1        move
yabai -m config mouse_action2        resize
yabai -m config mouse_drop_action    swap

_spaces=$(yabai -m query --spaces | jq 'length')
while [ "$_spaces" -lt 7 ]; do
  yabai -m space --create
  _spaces=$((_spaces + 1))
done
yabai -m space 1 --label mail
yabai -m space 2 --label web
yabai -m space 3 --label chat
yabai -m space 4 --label misc
yabai -m space 5 --label term
yabai -m space 6 --label latex
yabai -m space 7 --label read


yabai -m rule --add app="^Configuració del Sistema$" manage=off
yabai -m rule --add app="^Finder$" manage=off
yabai -m rule --add app="^Calculator$" manage=off
yabai -m rule --add app="^Karabiner-Elements$" manage=off
yabai -m rule --add app="^Karabiner-EventViewer$" manage=off
yabai -m rule --add app="^QuickTime Player$" manage=off
yabai -m rule --add app="^Monitor d'Activitat$" manage=off
yabai -m rule --add app="^Logi Options\+$" manage=off
yabai -m rule --add app="^Monitor" manage=off
yabai -m rule --add app="^Música$" manage=off
yabai -m signal --add event=window_title_changed app="^JabRef$" action='
  title="$(yabai -m query --windows --window $YABAI_WINDOW_ID | jq -r .title)"
  [ "$title" = "New entry" ] && yabai -m window $YABAI_WINDOW_ID --toggle float
'
# yabai -m rule --add app="^JabRef$" title!="^.*\.bib - JabRef" manage=off

# float child window
yabai -m signal --add event=window_created action='
  yabai -m query --windows --window $yabai_window_id | jq -er ".\"can-resize\" or .\"is-floating\"" || \
  yabai -m window $yabai_window_id --toggle float --layer above --grid 4:4:1:1:2:2
'

yabai -m signal --add event=space_changed   action="sketchybar --trigger space_focus"
yabai -m signal --add event=display_changed action="sketchybar --trigger space_focus"
